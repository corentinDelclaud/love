{
  "name": "love",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:api\" \"npm run dev:client\"",
    "dev:client": "vite --host 0.0.0.0",
    "dev:api": "cross-env API_PORT=8788 node server.mjs",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview"
  },
  "dependencies": {
    "nodemailer": "^9.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "cross-env": "^7.0.3",
    "concurrently": "^9.2.0",
    "oxlint": "^1.69.0",
    "typescript": "~6.0.2",
    "vite": "^5.4.19"
  }
}
